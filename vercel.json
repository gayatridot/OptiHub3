{
  "framework": null,
  "outputDirectory": ".",
  "buildCommand": "node build.js",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy",  "value": "credentialless" },
        { "key": "Cross-Origin-Resource-Policy",  "value": "cross-origin" }
      ]
    },
    {
      "source": "/ffmpeg-worker/(.*)\\.js",
      "headers": [
        { "key": "Content-Type",                 "value": "text/javascript" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    },
    {
      "source": "/js/(.*)\\.js",
      "headers": [
        { "key": "Content-Type",                 "value": "text/javascript" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/tts",         "destination": "/html/tts.html" },
    { "source": "/audio-video", "destination": "/html/audio-video.html" },
    { "source": "/compressor",  "destination": "/html/compressor.html" },
    { "source": "/about",       "destination": "/html/about.html" }
  ]
}
